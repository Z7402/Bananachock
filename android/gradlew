#!/usr/bin/env bash
##############################################################################
## Gradle start up script for POSIX generated by Gradle.
##############################################################################
PRG="$0"
while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=`dirname "$PRG"`"/$link"
    fi
done
SAVED="`pwd`"
cd "`dirname \"$PRG\"`/" >/dev/null
APP_HOME="`pwd -P`"
cd "$SAVED" >/dev/null
APP_NAME="Gradle"
APP_BASE_NAME=`basename "$0"`
MAX_FD="maximum"
warn () { echo "$*"; }
die () { echo; echo "$*"; echo; exit 1; }
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then JAVACMD="$JAVA_HOME/jre/sh/java"
    else JAVACMD="$JAVA_HOME/bin/java"; fi
else JAVACMD="java"; fi
GRADLE_DIST="$APP_HOME/gradle/wrapper/gradle-wrapper.properties"
if [ ! -f "$GRADLE_DIST" ]; then die "ERROR: Gradle wrapper properties file not found: $GRADLE_DIST"; fi
JVM_OPTS=()
GRADLE_OPTS=()
if [ -n "$GRADLE_USER_HOME" ]; then GRADLE_USER_HOME_DIR="$GRADLE_USER_HOME"
else GRADLE_USER_HOME_DIR="$HOME/.gradle"; fi
exec "$JAVACMD" $JVM_OPTS $GRADLE_OPTS -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" -Dorg.gradle.appname="$APP_BASE_NAME" org.gradle.wrapper.GradleWrapperMain "$@"
